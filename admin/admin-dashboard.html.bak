<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>

    <!-- CSS -->
    <link rel="stylesheet" href="../assets/style.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Background & Overlay -->
    <div class="bg-image"></div>
    <div class="bg-overlay"></div>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">
                <h1><i class="fas fa-graduation-cap"></i> Training Simulator</h1>
            </div>
            <ul class="nav-menu">
                <li class="nav-item"><a href="#" class="nav-links" id="logoutBtn">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <div class="dashboard-container">
            <div class="admin-container">
                <div class="login-header">
                    <h2>Welcome, Admin</h2>
                    <p>Use the tools below to manage the training system.</p>
                </div>

                <nav class="admin-nav-row">
                    <a href="register.html" class="admin-btn"><i class="fas fa-user-plus"></i> Register</a>
                    <a href="edit-user.html" class="admin-btn"><i class="fas fa-user-edit"></i> Edit Users</a>
                    <a href="view-score.html" class="admin-btn"><i class="fas fa-chart-line"></i> View Scores</a>
                </nav>
                
                <!-- User Information Table -->
<div class="user-table-container">
    <h3>User Information</h3>
    <table class="user-table">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Middle Name</th>
                <th>Last Name</th>
                <th>Age</th>
                <th>Email</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Jane</td>
                <td>A.</td>
                <td>Doe</td>
                <td>29</td>
                <td>jane.doe@example.com</td>
                <td>Admin</td>
            </tr>
            <tr>
                <td>John</td>
                <td>B.</td>
                <td>Smith</td>
                <td>34</td>
                <td>john.smith@example.com</td>
                <td>User</td>
            </tr>
            <!-- Add more rows as needed -->
        </tbody>
    </table>
</div>

            </div>
        </div>
    </div>

    <!-- Optional Footer -->
    <footer class="footer">
        <p>&copy; 2025 Training Simulator. All rights reserved.</p>
    </footer>

    <script type="module" src="assets/scripts.js"></script>
</body>
</html>
