<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Scores</title>
    <link rel="stylesheet" href="../assets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">
                <h1><i class="fas fa-graduation-cap"></i> Training Simulator</h1>
            </div>
            <ul class="nav-menu">
                 <li class="nav-item"><a href="admin-dashboard.html" class="nav-links">Admin Dashboard</a></li>
            </ul>
        </div>
    </nav>
    <div class="bg-image"></div>
    <div class="bg-overlay"></div>

    <div class="dashboard-container">
        <header>
            <h1><i class="fas fa-chart-line"></i> All User Scores</h1>
            <a href="admin-dashboard.html" class="back-btn"><i class="fas fa-arrow-left"></i> Back to Admin Dashboard</a>
        </header>

        <div class="content">
            <div class="filters">
                <label for="viewScoresActivityTypeFilter">Filter by Activity Type:</label>
                <select id="viewScoresActivityTypeFilter">
                    <option value="all">All Activities</option>
                    <option value="Training">Training</option>
                    <option value="Quiz">Quiz</option> <!-- Was Examination, now consolidated -->
                    <option value="Assessment">Assessment</option>
                    <option value="Maintenance">Maintenance</option>
                </select>

                <label for="viewScoresModuleFilter">Filter by Module (Keyword):</label>
                <select id="viewScoresModuleFilter">
                    <option value="all">All Modules</option>
                    <option value="antenna">Antenna Installation</option>
                    <option value="router">Router Installation</option>
                    <option value="crimping">Cable Crimping</option>
                    <option value="wisp">WISP Fundamentals</option>
                </select>

                <button id="viewTotalBtn" class="total-btn">
                    <i class="fas fa-calculator"></i> View Total Scores
                </button>
            </div>

            <table id="scoresTable" class="display" style="width:100%;">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Level/Activity Name</th>
                        <th>Score (%)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
						<td>Loading...</td>
						<td>Loading...</td>
						<td>Loading...</td>
					</tr>
                </tbody>
            </table>
        </div>

        <div id="totalScoresModal" class="modal">
            <div class="modal-content">
                <span class="close-btn" id="closeTotalScoresModalBtn">×</span>
                <h2><i class="fas fa-trophy"></i> Total Scores by User</h2>
                <div class="modal-filters">
                    <label for="totalScoreActivityTypeFilter">Activity Type for Totals:</label>
                    <select id="totalScoreActivityTypeFilter">
                        <option value="Training">Training</option>
                        <option value="Quiz">Quiz</option> <!-- Was Examination -->
                        <option value="Assessment">Assessment</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="table-container">
                    <table id="totalScoresTable">
                        <thead>
                            <tr id="totalScoresHeader">
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
                <div class="modal-actions">
                    <button id="exportTotalScoresBtn" class="export-btn">
                        <i class="fas fa-file-export"></i> Export to CSV
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <p>© 2025 Training Simulator. All rights reserved.</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script type="module" src="../assets/scripts.js"></script>
</body>
</html>